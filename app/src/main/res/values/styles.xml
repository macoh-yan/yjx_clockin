<resources>

    <!-- 主应用主题 -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>

        <!-- 全局字体：你自己的 fandango_bz 字体 -->
        <item name="android:fontFamily">@font/fandango_bz</item>
        <item name="fontFamily">@font/fandango_bz</item>

        <!-- 全局控件样式 -->
        <item name="android:textViewStyle">@style/MyTextViewStyle</item>
        <item name="editTextStyle">@style/MyEditTextStyle</item>
        <item name="buttonStyle">@style/MyButtonStyle</item>
    </style>

    <!-- 全局文字 -->
    <style name="MyTextViewStyle" parent="android:Widget.TextView">
        <item name="android:fontFamily">@font/fandango_bz</item>
        <item name="fontFamily">@font/fandango_bz</item>
    </style>

    <!-- 全局输入框 -->
    <style name="MyEditTextStyle" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:fontFamily">@font/fandango_bz</item>
        <item name="fontFamily">@font/fandango_bz</item>
    </style>

    <!-- 全局按钮 -->
    <style name="MyButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">@font/fandango_bz</item>
        <item name="fontFamily">@font/fandango_bz</item>
    </style>
    <style name="CustomAlertDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
    </style>

</resources>